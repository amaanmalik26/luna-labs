# Luna Labs environment template
# Copy these into Vercel Project Settings > Environment Variables.
# Do not commit real secrets to this file.

# Site URL used for auth redirects and canonical links
SITE_URL=https://www.lunalabs.site
PUBLIC_APP_URL=https://www.lunalabs.site

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY
SUPABASE_SECRET_KEY=sb_secret_YOUR_SECRET_KEY

# Discord webhook used by lead notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
